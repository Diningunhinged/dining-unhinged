---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
}

const {
  title = "Dining Unhinged | Food Reviews with Excellent Taste and Questionable Restraint",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>

    <meta
      name="description"
      content="Dining Unhinged is an independent restaurant review publication featuring honest reviews, exceptional cocktails, and unforgettable dining experiences."
    />

    <link rel="icon" href="/favicon.svg" />
  </head>

  <body>

    <Header />

    <main>
      <slot />
    </main>

    <Footer />

  </body>
</html>