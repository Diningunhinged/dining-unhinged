---
import MainLayout from "../../layouts/MainLayout.astro";
import { client } from "../../lib/sanity";
import { urlFor } from "../../lib/image";
import { PortableText } from "astro-portabletext";

export async function getStaticPaths() {
  const cocktails = await client.fetch(`
    *[_type == "cocktailReview"]{
      "slug": slug.current
    }
  `);

  return cocktails.map((cocktail: { slug: string }) => ({
    params: {
      slug: cocktail.slug,
    },
  }));
}

const { slug } = Astro.params;

const cocktail = await client.fetch(
  `
  *[_type == "cocktailReview" && slug.current == $slug][0]{
    title,
    storyHook,
    spirit,
    rating,
    publishedDate,
    heroImage,
    body,
    venue->{
      name,
      city,
      province
    }
  }
  `,
  { slug }
);

if (!cocktail) {
  throw new Error(`Cocktail review not found: ${slug}`);
}
---

<MainLayout title={`${cocktail.title} | Dining Unhinged`}>

  <section class="article-hero">

    <a href="/cocktails" class="back-link">
      ← Back to Cocktails
    </a>

    <p class="article-category">
      {cocktail.venue.name} • {cocktail.venue.city}, {cocktail.venue.province}
    </p>

    <h1>{cocktail.title}</h1>

    <div class="article-stars">
      {"★".repeat(cocktail.rating ?? 5)}
    </div>

    <p class="article-deck">
      {cocktail.storyHook}
    </p>

  </section>

  <section class="article-image">

    <img
      src={urlFor(cocktail.heroImage).width(1600).url()}
      alt={cocktail.title}
    />

  </section>

  <section class="review-details">

    <div class="detail-box">
      <span class="detail-label">Venue</span>
      <strong>{cocktail.venue.name}</strong>
    </div>

    <div class="detail-box">
      <span class="detail-label">Location</span>
      <strong>{cocktail.venue.city}, {cocktail.venue.province}</strong>
    </div>

    <div class="detail-box">
      <span class="detail-label">Primary Spirit</span>
      <strong>{cocktail.spirit}</strong>
    </div>

    <div class="detail-box">
      <span class="detail-label">Published</span>
      <strong>{cocktail.publishedDate}</strong>
    </div>

  </section>

  <section class="article-body">

    <PortableText value={cocktail.body} />

  </section>

</MainLayout>