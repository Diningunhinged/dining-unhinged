---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Cocktails | Dining Unhinged">

<section>

  <h1>Cocktails</h1>

  <p class="featured-summary">
    Great cocktails deserve great stories. From timeless classics to modern creations, Dining Unhinged explores exceptional cocktails, fine spirits, and the people who make them worth remembering.
  </p>

  <div class="restaurant-grid">

    <!-- Spanish Old Fashioned -->

    <article class="review-card">

      <img
        src="/images/spanish-old-fashioned.jpg"
        alt="Spanish Old Fashioned"
        class="review-image"
      />

      <div class="review-body">

        <p class="review-category">
          BODEGA ELLERSLIE • EDMONTON, ALBERTA
        </p>

        <h3>
          Spanish Old Fashioned
        </h3>

        <div class="review-rating">
          ★★★★★
        </div>

        <p class="review-excerpt">
          A refined twist on the classic Old Fashioned featuring Torres Brandy, Licor 43, and orange zest. Smooth, balanced, and unforgettable.
        </p>

        <a
          href="/cocktails/spanish-old-fashioned"
          class="read-story"
        >
          Read Story →
        </a>

      </div>

    </article>

    <!-- Caipirão -->

    <article class="review-card">

      <img
        src="/images/caipirao.jpg"
        alt="Caipirão"
        class="review-image"
      />

      <div class="review-body">

        <p class="review-category">
          BODEGA ELLERSLIE • EDMONTON, ALBERTA
        </p>

        <h3>
          Caipirão
        </h3>

        <div class="review-rating">
          ★★★★★
        </div>

        <p class="review-excerpt">
          Built around Licor Beirão and fresh lime juice, this vibrant cocktail delivers bright citrus, herbal sweetness, and far more personality than its appearance suggests.
        </p>

        <a
          href="/cocktails/caipirao"
          class="read-story"
        >
          Read Story →
        </a>

      </div>

    </article>

    <!-- Rebel Food & Drink -->

    <article class="review-card">

      <img
        src="/images/rebel-food-drink.jpg"
        alt="Rebel Food & Drink"
        class="review-image"
      />

      <div class="review-body">

        <p class="review-category">
          EDMONTON, ALBERTA
        </p>

        <h3>
          Rebel Food &amp; Drink
        </h3>

        <div class="review-rating">
          ★★★★★
        </div>

        <p class="review-excerpt">
          A flash flood, two exceptional cocktails, and a bartender whose deadpan humour was almost as memorable as the drinks themselves.
        </p>

        <a
          href="/cocktails/rebel-food-drink"
          class="read-story"
        >
          Read Story →
        </a>

      </div>

    </article>

  </div>

</section>

</MainLayout>